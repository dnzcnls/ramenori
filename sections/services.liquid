id="svcs01"
<section class="section services" id="menu">
  <div class="wrap">

    <div class="section-head is-centered reveal">
      <span class="eyebrow is-centered">
        {{ section.settings.eyebrow | default: 'Menu Highlights' }}
      </span>

      <h2 class="h-lg">
        {{ section.settings.heading | default: 'Crafted to be Savoured' }}
      </h2>

      <p class="lead" style="margin-top:18px;">
        {{ section.settings.subheading }}
      </p>
    </div>

    <div class="dishes">
      {%- for block in section.blocks -%}
        <article class="dish-card reveal" {{ block.shopify_attributes }}>

          <div class="dish-media">

            {%- if block.settings.tag != blank -%}
              <span class="dish-tag">{{ block.settings.tag }}</span>
            {%- endif -%}

            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            {%- endif -%}

          </div>

          <div class="dish-body">
            <div class="row">
              <h3>{{ block.settings.title }}</h3>
              <span class="dish-price">{{ block.settings.price }}</span>
            </div>
            <p>{{ block.settings.description }}</p>
          </div>

        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div style="text-align:center;margin-top:54px;" class="reveal">
        <a href="{{ section.settings.button_link | default: '#contact' }}" class="btn btn--ghost">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Services (Menu)",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Menu Highlights" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Crafted to be Savoured" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "View Full Menu" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "dish",
      "name": "Dish",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag", "label": "Tag" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "price", "label": "Price" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Services (Menu)",
      "blocks": [
        { "type": "dish" },
        { "type": "dish" },
        { "type": "dish" },
        { "type": "dish" }
      ]
    }
  ]
}
{% endschema %}

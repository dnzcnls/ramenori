```liquid
<section class="section gallery" id="gallery">
  <div class="wrap">
    <div class="section-head is-centered reveal">
      <span class="eyebrow is-centered">
        {{ section.settings.eyebrow | default: 'Photos' }}
      </span>
      <h2 class="h-lg">
        {{ section.settings.heading | default: 'A Taste of the Table' }}
      </h2>
    </div>

    <div class="gallery-grid reveal">
      {%- for block in section.blocks -%}
        <div class="gallery-item {{ block.settings.size }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              alt="{{ block.settings.alt | escape }}"
              loading="lazy"
              width="900"
              height="600"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gallery",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Photos"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Taste of the Table"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt Text",
          "default": "Gallery Image"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "default": "",
          "options": [
            {
              "value": "",
              "label": "Normal"
            },
            {
              "value": "tall",
              "label": "Tall"
            },
            {
              "value": "wide",
              "label": "Wide"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery",
      "blocks": [
        {
          "type": "photo"
        },
        {
          "type": "photo"
        },
        {
          "type": "photo"
        },
        {
          "type": "photo"
        },
        {
          "type": "photo"
        },
        {
          "type": "photo"
        }
      ]
    }
  ]
}
{% endschema %}
```

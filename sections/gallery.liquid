<section class="section gallery" id="gallery">
  <div class="wrap">

    <div class="section-head is-centered reveal">
      <span class="eyebrow is-centered">
        {{ section.settings.eyebrow | default: 'Photos' }}
      </span>
      <h2 class="h-lg">
        {{ section.settings.heading | default: 'A Taste of the Table' }}
      </h2>
    </div>

    <div class="gallery-grid">
      {%- for block in section.blocks -%}
        <div class="gallery-item" {{ block.shopify_attributes }}>
          
          {%- if block.settings.image != blank -%}
            <img 
              src="{{ block.settings.image | image_url: width: 800 }}" 
              alt="{{ block.settings.title | default: 'Gallery image' }}" 
              loading="lazy"
              width="800"
              height="600"
            >
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Gallery",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Photos"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Taste of the Table"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Gallery",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}

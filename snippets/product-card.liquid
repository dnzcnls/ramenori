{%- comment -%}
  Renders a product/dish card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}
<article class="dish-card">
  <a href="{{ product.url }}">
    <div class="dish-media">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="800" height="600">
      {%- endif -%}
    </div>
    <div class="dish-body">
      <div class="row">
        <h3>{{ product.title }}</h3>
        <span class="dish-price">{{ product.price | money }}</span>
      </div>
      {%- if product.description != blank -%}
        <p>{{ product.description | strip_html | truncatewords: 16 }}</p>
      {%- endif -%}
    </div>
  </a>
</article>

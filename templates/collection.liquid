<div class="page-hero">
  <div class="wrap">
    <span class="eyebrow is-centered">Our Menu</span>
    <h1 class="h-xl">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="lead" style="margin:18px auto 0;">{{ collection.description | strip_html | truncatewords: 30 }}</p>
    {%- endif -%}
  </div>
</div>

<section class="section">
  <div class="wrap">
    {%- if collection.products.size > 0 -%}
      <div class="collection-grid">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <div style="text-align:center;margin-top:50px;">{{ paginate | default_pagination }}</div>
      {%- endif -%}
    {%- else -%}
      <p class="lead" style="text-align:center;">No dishes in this collection yet.</p>
    {%- endif -%}
  </div>
</section>
